on gametest script and command context:
    loop all scripts:
        set {scriptcmd::legacy::all::%loop-index%} to loop-script
    loop all enabled scripts without paths:
        set {scriptcmd::legacy::enabled::%loop-index%} to loop-value
    set {scriptcmd::legacy::disabled_count} to 0
    loop all disabled scripts:
        add 1 to {scriptcmd::legacy::disabled_count}
